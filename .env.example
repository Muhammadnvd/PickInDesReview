PORT=3001
# Comma-separated list of allowed frontend origins. Leave empty for open CORS.
CORS_ORIGIN=http://localhost:5173
# Admin API credentials (required to enable admin routes)
ADMIN_USER=admin
ADMIN_PASSWORD=change-me
# Persistent data directory for products.db and uploads
DATA_DIR=./data
# Optional explicit overrides (usually not needed)
# DB_PATH=./data/products.db
# UPLOADS_DIR=./data/uploads
